pipeline {
    agent { 
        node { label 'docker-agent-python' }
    }

    environment {
        DOCKER_HUB_USER = 'khaliiiiid'
        REGISTRY_CREDENTIALS_ID = '3b09b7f8-9b77-449c-b075-12d42f983dfc'
        SERVICE_NAME = "mon-app-python"
        VERSION = "1.0.${BUILD_NUMBER}"
    }

    stages {
        stage('Step 1: Syntax Check (Zero Install)') {
            steps {
                script {
                    echo "Checking for Python syntax errors..."
                    // This uses Python's BUILT-IN compiler. 
                    // It requires NO installation and will stop Jenkins if you have a typo (missing :, etc.)
                    sh "python3 -m py_compile myapp/*.py"
                }
            }
        }

        stage('Step 2: Install & Run Tests') {
            steps {
                script {
                    echo "Installing test tools dynamically..."
                    // We use --user or --break-system-packages to avoid the error you had before
                    sh "pip install --user pytest flake8 || pip install --break-system-packages pytest flake8"
                    
                    echo "Running Linting (flake8)..."
                    // If flake8 finds errors, it returns exit code 1 and STOPS the pipeline
                    sh "python3 -m flake8 myapp/ --count --select=E9,F63,F7,F82 --show-source --statistics"

                    echo "Running Logic Tests (pytest)..."
                    // Fails if your code logic is wrong
                    sh "python3 -m pytest myapp/"
                }
            }
        }

        stage('Step 3: Build Docker Image') {
            // This stage ONLY runs if Step 1 and Step 2 passed!
            steps {
                script {
                    sh "docker build -t ${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION} ./myapp"
                }
            }
        }

        stage('Step 4: Push to Registry') {
            steps {
                script {
                    docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                        sh "docker push ${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION}"
                        sh "docker tag ${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION} ${DOCKER_HUB_USER}/${SERVICE_NAME}:latest"
                        sh "docker push ${DOCKER_HUB_USER}/${SERVICE_NAME}:latest"
                    }
                }
            }
        }
    }
}

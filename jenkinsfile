pipeline {
    agent { 
        node { label 'docker-agent-python' }
    }
environment {
    DOCKER_HUB_USER = 'khaliiiiid'
    REGISTRY_CREDENTIALS_ID = '3b09b7f8-9b77-449c-b075-12d42f983dfc'
    SERVICE_NAME = "mon-app-python"
    VERSION = "1.0.${BUILD_NUMBER}"
    FLASK_APP = "app.py"
    JENKINS_NODE_COOKIE = "dontKillMe" 
    DOCKER_API_VERSION = '1.44'
}

stages {
    stage('Install Dependencies') {
        steps {
            echo "Installing dependencies..."
            sh '''
            cd myapp
            pip install -r requirements.txt || echo "Pas de requirements.txt"
            '''
        }
    }
    stage('Test & Preview') {
        steps {
            script {
                // --- AJOUT DE LA VÉRIFICATION DE SYNTAXE (SANS INSTALLATION) ---
                echo "Vérification de la syntaxe du code..."
                sh "python3 -m py_compile myapp/*.py"
                
                // Si la syntaxe est OK, on continue le lancement habituel
                sh '''
                cd myapp
                export FLASK_APP=app.py
                python3 -m flask run --host=0.0.0.0 --port=5000 &
                '''
                echo "Attente du démarrage de Flask (10s)..."
                sleep 10
                input message: "Vérifie l'app sur le port 5000. Clique sur Proceed pour continuer."
            }
        }
    }        

    stage('Build Docker Image') {
        steps {
            script {
                echo "Construction de l'image Docker..."
                // Vérifie bien que ton Dockerfile est dans le dossier myapp/
                sh "docker build -t ${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION} ./myapp"
                sh "docker tag ${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION} ${DOCKER_HUB_USER}/${SERVICE_NAME}:latest"
            }
        }
    }

    stage('Push to Registry') {
        steps {
            script {
                // Utilisation sécurisée des identifiants Docker Hub
                docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                    echo "Push vers Docker Hub..."
                    sh "docker push ${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION}"
                    sh "docker push ${DOCKER_HUB_USER}/${SERVICE_NAME}:latest"
                }
            }
        }
    }
}

     stage('Deploy to Kubernetes') {
            steps {
                script {
                    // On utilise l'identifiant de tes credentials k3s (ex: 'k3s-auth')
                    withKubeConfig([credentialsId: 'k3s-auth']) {
                        echo "Déploiement de la version ${VERSION} sur k3s..."
                        
                        // 1. On remplace le texte 'IMAGE_TAG' par la vraie version dans le fichier YAML
                        sh "sed -i 's/IMAGE_TAG/${VERSION}/g' k8s/deployment.yaml"
                        
                        // 2. On applique la configuration au cluster
                        sh "kubectl apply -f k8s/deployment.yaml"
                        sh "kubectl apply -f k8s/service.yaml"
                        
                        // 3. On vérifie le déploiement
                        sh "kubectl rollout status deployment/flask-app-deployment"
                    }
                }
            }
        }

post {
    always {
        echo "Nettoyage du processus Flask..."
        sh 'pkill -f "flask run" || true'
    }
    success {
        echo "Pipeline réussi ! Image disponible sur Docker Hub."
        echo "Pipeline x v."
    }
  }
}

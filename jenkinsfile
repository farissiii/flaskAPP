pipeline {
    agent {
        kubernetes {
            // Utilise le nom de ton Cloud configuré dans Jenkins
            cloud 'kubernetes' 
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: python-docker
    image: python:3.9 # Image pour tes tests et pip
    command: ['cat']
    tty: true
  - name: kubectl
    image: bitnami/kubectl:latest # Image qui contient déjà kubectl
    command: ['cat']
    tty: true
'''
        }
    }

    environment {
        // Garde tes variables actuelles
        DOCKER_HUB_USER = 'khaliiiiid'
        SERVICE_NAME = "mon-app-python"
        VERSION = "1.0.${BUILD_NUMBER}"
        REGISTRY_CREDENTIALS_ID = '3b09b7f8-9b77-449c-b075-12d42f983dfc'
    }

    stages {
        // --- TES STAGES DE CI (Build & Push) ---
        // (Garde ce que tu as fait, utilise le container 'python-docker')

        // --- NOUVEAU STAGE DE CD (Le déploiement local) ---
        stage('Deploy to k3s Local') {
            steps {
                container('kubectl') { // On utilise le container qui a kubectl
                    script {
                        // Utilise l'ID de tes credentials k3s
                        withKubeConfig([credentialsId: 'k3s-auth']) {
                            echo "Déploiement sur le cluster local..."
                            
                            // 1. Appliquer les fichiers (Assure-toi que le dossier k8s existe)
                            sh "kubectl apply -f k8s/deployment.yaml"
                            sh "kubectl apply -f k8s/service.yaml"

                            // 2. LA MEILLEURE MÉTHODE : On met à jour l'image sans 'sed'
                            // C'est beaucoup plus robuste que de modifier le fichier texte
                            sh "kubectl set image deployment/flask-app-deployment flask-app=${DOCKER_HUB_USER}/${SERVICE_NAME}:${VERSION}"
                            
                            // 3. Vérification du statut
                            sh "kubectl rollout status deployment/flask-app-deployment"
                        }
                    }
                }
            }
        }
    }
}
